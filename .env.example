# Copy to .env and fill in. .env is gitignored.

# AWS
AWS_REGION=us-east-1
# Only set AWS_PROFILE if you've actually configured a named profile via
# `aws configure --profile financial-pipeline`. Otherwise leave it commented
# out so the CLI falls back to your default profile / env credentials.
# AWS_PROFILE=financial-pipeline

# Resource names (set after Phase 2/3 provisioning)
KINESIS_STREAM_NAME=financial-price-events
DYNAMODB_TABLE_NAME=FinancialPriceEvents
S3_RAW_BUCKET=financial-pipeline-raw
DLQ_URL=

# Fetcher Lambda config
TICKERS=AAPL,TSLA,BTC-USD,ETH-USD
# Finnhub free-tier API key for stock quotes — sign up at https://finnhub.io
FINNHUB_API_KEY=

# Billing alarm
BILLING_ALERT_EMAIL=you@example.com
BILLING_ALERT_THRESHOLD_USD=5
